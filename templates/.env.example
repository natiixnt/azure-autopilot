# Project metadata used by scripts/provision.sh + auth.sh
PROJECT=acme           # short slug, used in resource names
LOCATION=westeurope    # default region

# CI/CD identity (after running scripts/auth.sh sp-create + sp-federate)
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# AAD group object IDs
SQL_ADMIN_GROUP_OBJECT_ID=00000000-0000-0000-0000-000000000000
PBI_ADMIN_GROUP_OBJECT_ID=00000000-0000-0000-0000-000000000000

# Notification emails (comma-separated for multi)
NOTIFY_EMAIL=platform-team@acme.com

# Override Bicep file/param paths (optional)
# BICEP_FILE=./bicep/main.bicep
# PARAM_FILE=./bicep/parameters/dev.bicepparam
